# ===== mahoroba-app-tree 環境変数テンプレート =====
# 実際の値は .env にコピーして利用。.env は git 管理外。

# ----- 動作モード -----
NODE_ENV=development
PORT=3002

# ----- 共通ログイン -----
# パスワードは bcrypt ハッシュを格納（平文禁止）
# 生成例: node -e "console.log(require('bcrypt').hashSync('1123', 12))"
COMMON_LOGIN_ID=mahoroba-construction
COMMON_LOGIN_PASS_HASH=$2b$12$REPLACE_WITH_BCRYPT_HASH_OF_1123

# ----- セッション -----
SESSION_SECRET=REPLACE_WITH_64CHAR_RANDOM_HEX
SESSION_COOKIE_SECURE=false   # 本番は true（HTTPS必須）
SESSION_MAX_AGE_MS=3600000    # 1 時間

# ----- mahoroba-app 連携（管理者認証 API） -----
MAHOROBA_APP_BASE_URL=http://localhost:3001
MAHOROBA_APP_AUTH_API=/api/auth/verify-admin
MAHOROBA_APP_SHARED_SECRET=REPLACE_WITH_SHARED_SECRET_FOR_INTERNAL_API

# ----- ヘルス監視対象 -----
# config/apps.json で URL 切替（NODE_ENV で local/production を選択）

# ----- ログ -----
LOG_DIR=./logs
LOG_LEVEL=info

# ----- レート制限 -----
RATE_LIMIT_GLOBAL_PER_MIN=100
RATE_LIMIT_LOGIN_PER_MIN=10
RATE_LIMIT_RAG_PER_MIN=30

# ----- ブルートフォース対策 -----
LOGIN_LOCKOUT_THRESHOLD=5
LOGIN_LOCKOUT_DURATION_MS=900000   # 15 分
